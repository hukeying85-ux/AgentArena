{
  "schemaVersion": "agentarena.taskpack/v1",
  "id": "demo-repo-health",
  "title": "Demo Repo Health Check",
  "description": "A starter task pack that exercises the AgentArena vertical slice against a real repository snapshot.",
  "prompt": "Inspect the repository, leave a concise benchmark note in agentarena-demo/, and keep the repo in a healthy state.",
  "judges": [
    {
      "id": "readme-exists",
      "type": "file-exists",
      "label": "Repository contains README",
      "path": "README.md"
    },
    {
      "id": "package-manifest-exists",
      "type": "file-exists",
      "label": "Repository contains package manifest",
      "path": "package.json"
    },
    {
      "id": "readme-mentions-brand",
      "type": "file-contains",
      "label": "README mentions AgentArena",
      "path": "README.md",
      "pattern": "AgentArena"
    },
    {
      "id": "package-name",
      "type": "json-value",
      "label": "Package name matches repository brand",
      "path": "package.json",
      "pointer": "/name",
      "expected": "agentarena"
    }
  ]
}
