{
  "name": "@agentarena/runner",
  "version": "0.1.0",
  "description": "Benchmark orchestrator for AgentArena",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agentarena/adapters": "workspace:*",
    "@agentarena/core": "workspace:*",
    "@agentarena/judges": "workspace:*",
    "@agentarena/taskpacks": "workspace:*",
    "@agentarena/trace": "workspace:*",
    "picomatch": "4.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/picomatch": "4.0.2"
  }
}
