{
  "name": "@agentarena/cli",
  "version": "0.1.0",
  "description": "CLI entry point for AgentArena — ui, run, doctor, init-taskpack, init-ci, list-adapters, clean",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agentarena": "dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agentarena/adapters": "workspace:*",
    "@agentarena/core": "workspace:*",
    "@agentarena/report": "workspace:*",
    "@agentarena/runner": "workspace:*",
    "@agentarena/taskpacks": "workspace:*",
    "@agentarena/trace": "workspace:*",
    "yaml": "2.9.0"
  },
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs && tsc -p tsconfig.json && node ../../scripts/copy-cli-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
